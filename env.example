# ============================================================
# 伏羲 (Fuxi) 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入真实值：
#   cp .env.example .env
# ============================================================

# --- 核心 API 密钥 ---

# 伏羲 API 访问密钥（保护 API 服务器）
FUXI_API_KEY=your_fuxi_api_key_here

# SiliconFlow API Key（向量嵌入服务）
# 获取地址: https://www.siliconflow.cn/
SILICONFLOW_KEY=your_siliconflow_api_key_here

# --- LLM 后端配置 ---

# MiniMax API Key（主会话模型）
MINIMAX_API_KEY=your_minimax_api_key_here

# DeepSeek API Key（编程/子代理模型）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenRouter API Key（限流兜底）
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- 飞书集成 ---

# 飞书应用凭证（从飞书开放平台获取）
# 获取地址: https://open.feishu.cn/app
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here

# 飞书知识库节点（知识挖掘引擎使用）
# 在知识库中创建「目录一」作为根目录，将节点 token 和 space_id 填入
FUXI_FEISHU_WIKI_ROOT_NODE=your_wiki_root_node_here
FUXI_FEISHU_WIKI_SPACE_ID=your_wiki_space_id_here

# --- 数据库 ---

# PostgreSQL 密码（启用 PG 向量存储时需要）
DB_PG_PASSWORD=your_postgres_password_here

# --- 其他可选配置 ---

# OpenClaw Gateway（默认: http://127.0.0.1:18789）
# OPENCLAW_GATEWAY=http://127.0.0.1:18789

# QQ OpenID（ Persona 引擎主动推送目标，可选）
# QQ_OPENID=your_qq_openid_here

# 引擎分层（essential/standard/advanced/all，默认: standard）
# ENGINE_TIER=standard

# 日志级别（DEBUG/INFO/WARNING/ERROR，默认: INFO）
# LOG_LEVEL=INFO